# Vault path (Markdown + Obsidian + Git) - 絶対パス推奨
VAULT_PATH=/path/to/your/vault/docs

# Model path for llama-cpp-python (switch between 1B and 4B)
MODEL_DIR=/path/to/your/models
MODEL_PATH_GEMMA_1B=${MODEL_DIR}/gemma-3-1b-it-q4_0.gguf
MODEL_PATH_GEMMA_4B=${MODEL_DIR}/gemma-3-4b-it-qat-q4_0.gguf
MODEL_PATH=${MODEL_PATH_GEMMA_1B}

# MCP Server configuration
MCP_PORT=3333
MCP_SERVER_URL=http://localhost:3333

# Supabase local (supabase start で取得した値を設定)
# DATABASE_URL のパスワードは supabase start 出力の DB URL から取得してください
# (Supabase ローカル開発環境の既定値は postgres)
SUPABASE_URL=http://127.0.0.1:54324
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-db-password@127.0.0.1:54325/postgres

# RAG チューニング（任意）
RAG_DB_MAX_CONCURRENCY=4
RAG_DB_QUERY_TIMEOUT_SEC=60
KB_COMPARE_WIKI_MAX_SELECTED_DOCS=4
KB_COMPARE_WIKI_SOURCE_DOCS=3
KB_COMPARE_WIKI_SOURCE_CONCURRENCY=1
KB_COMPARE_WIKI_GENERATE_SOURCE_DOCS=true
KB_COMPARE_RAG_MAX_DOCS=4
KB_COMPARE_RAG_MAX_CONTEXT_CHARS=9000
KB_COMPARE_STAGE_GAP_MS=250

# News/Blog 機能（任意）
KB_BLOG_SOURCE_PATH=/path/to/your/blog-source
KB_NEWS_OUTPUT_PATH=/path/to/your/blog

